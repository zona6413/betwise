# ── API Keys ───────────────────────────────────────────────────────────────────
# API-Football (https://www.api-sports.io/)
# Gratuit : 100 req/jour — Payant pour production
API_FOOTBALL_KEY=your_api_football_key_here

# TheOddsAPI (https://the-odds-api.com/)
# Gratuit : 500 req/mois — Payant pour production
ODDS_API_KEY=your_odds_api_key_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── Cache ──────────────────────────────────────────────────────────────────────
# Durée du cache en secondes (évite de brûler les quotas API)
CACHE_TTL=300
